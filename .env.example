# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change-me-32-chars-minimum
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me

# Processing API
PROCESSING_API_PORT=8000
MAX_UPLOAD_MB=75
MIN_TEXT_CHARS_FOR_NATIVE_PDF=800

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FILE_SEARCH_STORE=
ENABLE_GEMINI_FILE_SEARCH_UPLOAD=false

# Google Cloud Document AI OCR, optional but recommended for scanned PDFs.
# JSON key on host. Keep the file inside secrets/ and never commit it.
GOOGLE_APPLICATION_CREDENTIALS_HOST=./secrets/google_application_credentials.json
GOOGLE_CLOUD_PROJECT=
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google_application_credentials.json
